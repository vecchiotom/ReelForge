# ── PostgreSQL ────────────────────────────────────────────
POSTGRES_USER=postgres
POSTGRES_PASSWORD=postgres
POSTGRES_DB=reelforge
POSTGRES_PORT=5432
# ── MinIO (S3-compatible storage) ────────────────────────
MINIO_ACCESS_KEY=minioadmin
MINIO_SECRET_KEY=minioadmin
MINIO_BUCKET=reelforge
MINIO_API_PORT=9000
MINIO_CONSOLE_PORT=9001

# ── RabbitMQ ─────────────────────────────────────────────
RABBITMQ_USER=guest
RABBITMQ_PASSWORD=guest
RABBITMQ_PORT=5672
RABBITMQ_MGMT_PORT=15672

# ── JWT ──────────────────────────────────────────────────
JWT_SIGNING_KEY=change-me-to-a-strong-secret
JWT_ISSUER=reelforge-api
JWT_AUDIENCE=reelforge-inference

# ── Azure OpenAI ─────────────────────────────────────────
AZURE_OPENAI_ENDPOINT=
AZURE_OPENAI_API_KEY=
AZURE_OPENAI_DEPLOYMENT=gpt-4o-mini

# ── SMTP (optional — logs OTP to console if not set) ────
SMTP_HOST=
SMTP_PORT=587
SMTP_USERNAME=
SMTP_PASSWORD=
SMTP_FROM=

# ── Initial Admin User ──────────────────────────────────
ADMIN_EMAIL=admin@reelforge.local
ADMIN_PASSWORD=test

# ── Workflow Engine ──────────────────────────────────────
WORKFLOW_MAX_CONCURRENCY=4

# ── Service Ports (host-side) ────────────────────────────
APP_PORT=80
API_PORT=3000
INFERENCE_PORT=3001

# ── ASP.NET Environment ─────────────────────────────────
# Development = Swagger enabled | Production = Swagger disabled
ASPNETCORE_ENVIRONMENT=Development