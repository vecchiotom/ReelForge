# ── PostgreSQL ────────────────────────────────────────────
POSTGRES_USER=postgres
POSTGRES_PASSWORD=postgres
POSTGRES_DB=reelforge
POSTGRES_PORT=5432
# ── MinIO (S3-compatible storage) ────────────────────────
MINIO_ACCESS_KEY=minioadmin
MINIO_SECRET_KEY=minioadmin
MINIO_BUCKET=reelforge
MINIO_API_PORT=9000
MINIO_CONSOLE_PORT=9001

# ── RabbitMQ ─────────────────────────────────────────────
RABBITMQ_USER=guest
RABBITMQ_PASSWORD=guest
RABBITMQ_PORT=5672
RABBITMQ_MGMT_PORT=15672

# ── JWT ──────────────────────────────────────────────────
JWT_SIGNING_KEY=change-me-to-a-strong-secret
JWT_ISSUER=reelforge-api
JWT_AUDIENCE=reelforge-inference

# ── Azure OpenAI ─────────────────────────────────────────
AZURE_OPENAI_ENDPOINT=
AZURE_OPENAI_API_KEY=
AZURE_OPENAI_DEPLOYMENT=gpt-4o-mini
AZURE_OPENAI_EMBEDDING_DEPLOYMENT=text-embedding-3-large

# ── SMTP (optional — logs OTP to console if not set) ────
SMTP_HOST=
SMTP_PORT=587
SMTP_USERNAME=
SMTP_PASSWORD=
SMTP_FROM=

# ── Initial Admin User ──────────────────────────────────
ADMIN_EMAIL=admin@reelforge.local
ADMIN_PASSWORD=test

# ── Workflow Engine ──────────────────────────────────────
WORKFLOW_MAX_CONCURRENCY=4
VECTOR_QDRANT_GRPC_PORT=6334
VECTOR_CHUNK_SIZE_TOKENS=512
VECTOR_CHUNK_OVERLAP_TOKENS=64
VECTOR_SMALL_FILE_THRESHOLD_TOKENS=1500

# ── Service Ports (host-side) ────────────────────────────
APP_PORT=80
API_PORT=3000
INFERENCE_PORT=3001

# ── ASP.NET Environment ─────────────────────────────────
# Development = Swagger enabled | Production = Swagger disabled
ASPNETCORE_ENVIRONMENT=Development

# ── Next.js Web App Build Mode ──────────────────────────
# development = Turbopack dev server with hot reload (requires volumes)
# production  = Precompiled standalone build (optimized, no hot reload)
WEB_BUILD_TARGET=development
WEB_NODE_ENV=development

# Note: When using WEB_BUILD_TARGET=production:
# 1. Comment out or remove the volume mounts in docker-compose.yml web service
# 2. Set WEB_NODE_ENV=production
# 3. The app will run the optimized, precompiled standalone server