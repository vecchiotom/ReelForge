    "@react-three/drei": "^9.120.4",
    "@react-three/fiber": "^8.17.10",
    "d3": "^7.9.0",
    "framer-motion": "^11.14.4",
    "react": "^18.3.1",
    "react-dom": "^18.3.1",
    "remotion": "^4.0.318",
    "three": "^0.172.0"
  },
  "devDependencies": {
    "@types/react": "^18.3.18",
